{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "cmake",
			"type": "shell",
			"command": "cmake",
			"args": [
				"-G",
				"Ninja",
				"-DCMAKE_BUILD_TYPE=Release",
				"-S",
				"${workspaceFolder}",
				"-B",
				"${workspaceFolder}/build/release/"
			],
			"presentation": {
				"echo": false,
				"reveal": "silent",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": false,
				"clear": true,
				"close": false
			},
			"group": "none"
		},
		{
			"label": "cmake (debug)",
			"type": "shell",
			"command": "cmake",
			"args": [
				"-G",
				"Ninja",
				"-DCMAKE_BUILD_TYPE=Debug",
				"-S",
				"${workspaceFolder}",
				"-B",
				"${workspaceFolder}/build/debug/"
			],
			"presentation": {
				"echo": false,
				"reveal": "silent",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": false,
				"clear": true,
				"close": false
			},
			"group": "none"
		},
		{
			"label": "build",
			"type": "shell",
			"command": "ninja -j 8 && echo ======== BUILD SUCCESSFUL ========",
			"options": {
				"cwd": "${workspaceFolder}/build/release/"
			},
			"presentation": {
				"echo": false,
				"reveal": "silent",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": false,
				"clear": true,
				"close": false
			},
			"dependsOn": "cmake",
			"group": "build"
		},
		{
			"label": "build (debug)",
			"type": "shell",
			"command": "ninja -j 8 && echo ======== BUILD SUCCESSFUL ========",
			"options": {
				"cwd": "${workspaceFolder}/build/debug/"
			},
			"presentation": {
				"echo": false,
				"reveal": "silent",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": false,
				"clear": true,
				"close": false
			},
			"dependsOn": "cmake (debug)",
			"group": "build"
		},
		{
			"label": "run (+build)",
			"type": "shell",
			"command": "${workspaceFolder}/build/release/src/main/fracture",
			"options": {
				"cwd": "${workspaceFolder}/run/"
			},
			"presentation": {
				"echo": false,
				"reveal": "always",
				"focus": true,
				"panel": "shared",
				"showReuseMessage": false,
				"clear": true,
				"close": false
			},
			"group": "test",
			"dependsOn": "build"
		},
		{
			"label": "run",
			"type": "shell",
			"command": "${workspaceFolder}/build/release/src/main/fracture",
			"options": {
				"cwd": "${workspaceFolder}/run/"
			},
			"presentation": {
				"echo": false,
				"reveal": "always",
				"focus": true,
				"panel": "shared",
				"showReuseMessage": false,
				"clear": true,
				"close": false
			},
			"group": "test"
		}
	]
}